@page "/"
@using Microsoft.AspNetCore.Components.Web
@namespace MyPortfolio.Pages
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Senior software engineer with 7+ years of experience in .NET, Azure, React, Angular and cloud technologies. Portfolio of Mark Smith." />
    <meta property="og:title" content="Mark Smith — Senior Software Engineer" />
    <meta property="og:description" content="Senior software engineer with 7+ years of experience in .NET, Azure, React, Angular and cloud technologies." />
    <meta property="og:image" content="https://marksmith-portfolio.azurewebsites.net/favicon.png" />
    <meta property="og:url" content="https://marksmith-portfolio.azurewebsites.net" />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content="Mark Smith — Senior Software Engineer" />
    <meta name="twitter:description" content="Senior software engineer with 7+ years of experience in .NET, Azure, React, Angular and cloud technologies." />
    <base href="~/" />
    <link rel="stylesheet" href="bootstrap/bootstrap.min.css" />
    <link rel="stylesheet" href="app.css" />
    <link rel="stylesheet" href="css/timeline.css" />
    <link rel="stylesheet" href="css/microinteractions.css" />
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css" />
    <link rel="icon" type="image/png" href="favicon.png" />
    <script>(function(){var t=localStorage.getItem('theme')||'light';document.documentElement.setAttribute('data-theme',t);document.documentElement.setAttribute('data-bs-theme',t);})();</script>
    <component type="typeof(HeadOutlet)" render-mode="ServerPrerendered" />
</head>
<body>
    <component type="typeof(MyPortfolio.Components.App)" render-mode="ServerPrerendered" />

    <script src="js/theme.js"></script>
    <script src="_framework/blazor.server.js"></script>
    <script src="bootstrap/bootstrap.bundle.min.js"></script>
    <script src="js/microinteractions.js"></script>
</body>
</html> 