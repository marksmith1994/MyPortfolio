@inject IJSRuntime JSRuntime

<ul class="navbar-nav me-auto">
    <li class="nav-item">
        <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
            <i class="fas fa-home me-2"></i> Home
        </NavLink>
    </li>
    <li class="nav-item">
        <NavLink class="nav-link" href="projects">
            <i class="fas fa-code me-2"></i> Projects
        </NavLink>
    </li>
    <li class="nav-item">
        <NavLink class="nav-link" href="skills">
            <i class="fas fa-user-graduate me-2"></i> Skills
        </NavLink>
    </li>
    <li class="nav-item">
        <NavLink class="nav-link" href="contact">
            <i class="fas fa-envelope me-2"></i> Contact
        </NavLink>
    </li>
</ul>

<button class="btn btn-link nav-link theme-toggle-btn ms-2" @onclick="ToggleThemeAsync" title="Toggle dark/light mode">
    <i class="fas @(isDark ? "fa-sun" : "fa-moon")"></i>
</button>

@code {
    private bool isDark = false;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var theme = await JSRuntime.InvokeAsync<string>("applyStoredTheme");
            isDark = theme == "dark";
            StateHasChanged();
        }
    }

    private async Task ToggleThemeAsync()
    {
        var newTheme = await JSRuntime.InvokeAsync<string>("toggleTheme");
        isDark = newTheme == "dark";
    }
}
