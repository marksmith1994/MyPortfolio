@page "/nasa-apod"
@using MyPortfolio.Services
@inject NasaService NasaService

<PageTitle>NASA Astronomy Picture of the Day</PageTitle>

<div class="container py-5">
    <h1 class="text-center mb-2">NASA Astronomy Picture of the Day</h1>
    <p class="text-center text-muted mb-4">Browse any date back to June 16, 1995</p>

    <div class="d-flex justify-content-center align-items-center gap-2 mb-4 flex-wrap">
        <input type="date" class="form-control" style="max-width: 200px;"
               min="1995-06-16" max="@maxDate"
               @bind="selectedDate" @bind:format="yyyy-MM-dd"
               @bind:after="LoadApodAsync" />
        <button class="btn btn-outline-primary" @onclick="LoadRandomAsync" title="Load a random APOD">
            <i class="fas fa-random me-1"></i>Random
        </button>
        <button class="btn btn-outline-secondary" @onclick="LoadTodayAsync" title="Go back to today">
            <i class="fas fa-calendar-day me-1"></i>Today
        </button>
    </div>

    @if (isLoading)
    {
        <div class="text-center">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
        </div>
    }
    else if (errorMessage != null)
    {
        <div class="alert alert-danger text-center mx-auto" style="max-width: 700px;">@errorMessage</div>
    }
    else if (apod != null)
    {
        <div class="card mx-auto" style="max-width: 700px;">
            @if (!string.IsNullOrEmpty(apod.Url))
            {
                var mediaType = string.IsNullOrEmpty(apod.MediaType) ? "image" : apod.MediaType;
                if (mediaType == "image")
                {
                    <img src="@apod.Url" class="card-img-top" alt="@apod.Title" />
                }
                else if (mediaType == "video")
                {
                    <div class="ratio ratio-16x9">
                        <iframe src="@apod.Url" frameborder="0" allowfullscreen></iframe>
                    </div>
                }
            }
            <div class="card-body">
                <h5 class="card-title">@apod.Title</h5>
                <p class="card-text">@apod.Explanation</p>
                <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mt-3">
                    <small class="text-muted"><i class="fas fa-calendar me-1"></i>@apod.Date</small>
                    @if (!string.IsNullOrEmpty(apod.Copyright))
                    {
                        <small class="text-muted">&copy; @apod.Copyright</small>
                    }
                    @{
                        var apodDateStr = DateTime.TryParse(apod.Date, out var pd) ? pd.ToString("yyMMdd") : "";
                    }
                    @if (!string.IsNullOrEmpty(apodDateStr))
                    {
                        <a href="https://apod.nasa.gov/apod/ap@(apodDateStr).html" target="_blank" rel="noopener" class="btn btn-outline-primary btn-sm">
                            <i class="fas fa-external-link-alt me-1"></i>View on NASA
                        </a>
                    }
                </div>
            </div>
        </div>
    }
</div>

@code {
    private ApodResult? apod;
    private bool isLoading = true;
    private string? errorMessage;
    private DateTime selectedDate = DateTime.Today;
    private string maxDate = DateTime.Today.ToString("yyyy-MM-dd");
    private static readonly DateTime FirstApodDate = new DateTime(1995, 6, 16);

    protected override async Task OnInitializedAsync()
    {
        await LoadApodAsync();
    }

    private async Task LoadApodAsync()
    {
        isLoading = true;
        errorMessage = null;
        try
        {
            apod = await NasaService.GetApodAsync(selectedDate.ToString("yyyy-MM-dd"));
            if (apod == null) errorMessage = "No image found for this date.";
        }
        catch
        {
            errorMessage = "Could not load the picture. Please try another date.";
        }
        isLoading = false;
    }

    private async Task LoadRandomAsync()
    {
        var range = (DateTime.Today - FirstApodDate).Days;
        selectedDate = FirstApodDate.AddDays(Random.Shared.Next(range));
        await LoadApodAsync();
    }

    private async Task LoadTodayAsync()
    {
        selectedDate = DateTime.Today;
        await LoadApodAsync();
    }
}
