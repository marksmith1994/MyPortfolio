@page "/spacex"
@using MyPortfolio.Services
@inject SpaceXService SpaceXService

<link href="css/spacex.css" rel="stylesheet">

<PageTitle>SpaceX Launches</PageTitle>

<div class="container py-5">
    <h1 class="text-center mb-2">SpaceX Launches</h1>
    <p class="text-center text-muted mb-4">Real-time data from the SpaceX API</p>

    <div class="d-flex justify-content-center align-items-center gap-2 flex-wrap mb-4">
        <button class="btn @(showUpcoming ? "btn-primary" : "btn-outline-primary")" @onclick="ShowUpcoming">
            <i class="fas fa-rocket me-2"></i>Upcoming
        </button>
        <button class="btn @(!showUpcoming ? "btn-primary" : "btn-outline-primary")" @onclick="ShowPast">
            <i class="fas fa-history me-2"></i>Past
        </button>
        <select class="form-select w-auto" @bind="successFilter" @bind:after="StateHasChanged">
            <option value="all">All outcomes</option>
            <option value="success">Success</option>
            <option value="failure">Failure</option>
            <option value="tbd">TBD</option>
        </select>
    </div>

    @if (isLoading)
    {
        <div class="text-center"><div class="spinner-border text-primary" role="status"></div></div>
    }
    else if (launches != null && launches.Count > 0)
    {
        var filtered = successFilter switch
        {
            "success" => launches.Where(l => l.Success == true).ToList(),
            "failure" => launches.Where(l => l.Success == false).ToList(),
            "tbd"     => launches.Where(l => l.Success == null).ToList(),
            _         => launches
        };

        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
            @foreach (var launch in filtered)
            {
                <div class="col">
                    <div class="card h-100 spacex-card">
                        <div class="spacex-card-header">
                            @if (!string.IsNullOrEmpty(launch.Links.Patch?.Small))
                            {
                                <img src="@launch.Links.Patch.Small" alt="@launch.Name mission patch" class="mission-patch" />
                            }
                            else
                            {
                                <div class="mission-patch-placeholder">
                                    <i class="fas fa-rocket"></i>
                                </div>
                            }
                            <div class="outcome-badge @GetOutcomeClass(launch.Success)">
                                @GetOutcomeLabel(launch.Success)
                            </div>
                        </div>
                        <div class="card-body">
                            <h5 class="card-title">@launch.Name</h5>
                            <p class="card-text text-muted small mb-1">
                                <i class="fas fa-calendar me-1"></i>
                                @(launch.DateUtc == DateTime.MinValue ? "TBD" : launch.DateUtc.ToLocalTime().ToString("dd MMM yyyy, HH:mm"))
                            </p>
                            <p class="card-text text-muted small mb-2">
                                <i class="fas fa-rocket me-1"></i>@launch.Rocket
                            </p>
                            @if (!string.IsNullOrEmpty(launch.Details))
                            {
                                <p class="card-text small launch-details">@launch.Details</p>
                            }
                        </div>
                        @if (!string.IsNullOrEmpty(launch.Links.Webcast))
                        {
                            <div class="card-footer bg-transparent border-top-0 pt-0">
                                <a href="@launch.Links.Webcast" target="_blank" class="btn btn-outline-primary btn-sm w-100">
                                    <i class="fab fa-youtube me-1"></i>Watch Webcast
                                </a>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>

        @if (!filtered.Any())
        {
            <div class="alert alert-info text-center">No launches match that filter.</div>
        }
    }
    else if (errorMessage != null)
    {
        <div class="alert alert-danger text-center">@errorMessage</div>
    }
    else
    {
        <div class="alert alert-info text-center">No launches found.</div>
    }
</div>

@code {
    private List<Launch> launches = new();
    private bool isLoading = false;
    private string? errorMessage;
    private bool showUpcoming = true;
    private string successFilter = "all";

    protected override async Task OnInitializedAsync()
    {
        await LoadLaunchesAsync();
    }

    private async Task LoadLaunchesAsync()
    {
        isLoading = true;
        errorMessage = null;
        try
        {
            launches = showUpcoming
                ? await SpaceXService.GetUpcomingLaunchesAsync()
                : await SpaceXService.GetPastLaunchesAsync();
        }
        catch
        {
            errorMessage = "Could not fetch SpaceX launches. Please try again later.";
            launches = new();
        }
        isLoading = false;
    }

    private async Task ShowUpcoming() { showUpcoming = true; await LoadLaunchesAsync(); }
    private async Task ShowPast()     { showUpcoming = false; await LoadLaunchesAsync(); }

    private static string GetOutcomeClass(bool? success) => success switch
    {
        true  => "outcome-success",
        false => "outcome-failure",
        _     => "outcome-tbd"
    };

    private static string GetOutcomeLabel(bool? success) => success switch
    {
        true  => "Success",
        false => "Failure",
        _     => "TBD"
    };
}
